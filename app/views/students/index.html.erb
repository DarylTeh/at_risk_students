<div class="dashboard-container">
  <header class="dashboard-header">
    <h1>📊 At-Risk Students Dashboard</h1>
    <p>Review student progress and risk status in one clean view.</p>
  </header>

  <table class="students-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Course</th>
        <th>Last Active</th>
        <th>Progress</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @students.each do |s| %>
        <tr class="<%= s.at_risk? ? 'risk-row' : 'safe-row' %>">
          <td><%= s.name %></td>
          <td><%= s.course.name %></td>
          <td><%= s.last_active_at&.to_date %></td>
          <td><%= s.progress %>%</td>
          <td>
            <span class="status-badge <%= s.at_risk? ? 'risk' : 'safe' %>">
              <%= s.at_risk? ? '⚠️ At Risk' : '✅ Good' %>
            </span>
          </td>
          <td>
            <%= link_to "View", s, class: "button secondary" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>